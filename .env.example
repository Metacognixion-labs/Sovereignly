# ═══════════════════════════════════════════════════════════════════════════════
# Sovereignly v3.0.1 — Environment Variables
# Copy to .env and fill in values.  Only the first 3 are required to start.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Required (server won't start correctly without these) ─────────────────────
SOVEREIGN_SERVER_KEY=           # openssl rand -hex 32 — encrypts ALL tenant data. NEVER CHANGE.
JWT_SECRET=                     # openssl rand -hex 32 — JWT signing key
ADMIN_TOKEN=                    # openssl rand -hex 16 — admin API bearer token

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787
DATA_DIR=./data
WORKER_POOL_SIZE=4
LOG_LEVEL=minimal               # minimal | verbose | silent
SOVEREIGN_NODE_ID=primary
SOVEREIGN_DOMAIN=               # e.g. sovereignly.io — passkey rpId + OAuth redirects
CORS_ORIGINS=*
RATE_LIMIT=600

# ── Omnichain Attestation ────────────────────────────────────────────────────
ANCHOR_TIER=starter             # free | starter | growth | enterprise
CHAIN_ANCHOR_INTERVAL=100
GLOBAL_ANCHOR_INTERVAL=100
EAS_SIGNER_KEY=                 # 0x<32-byte-evm-private-key>
EAS_SCHEMA_UID=0xa3518350e4a3857be49837596827c326dad06d71a9ed18cd883774118c1e90dc
EAS_BASE_RPC=https://mainnet.base.org
EAS_ARB_RPC=https://arb1.arbitrum.io/rpc
SIGN_SCHEMA_ID=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_ANCHOR_KEY=
IRYS_SIGNER_KEY=
BITCOIN_WIF=

# ── OAuth Providers (optional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe Billing (optional) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_STARTER_ANNUAL=    # price_... ($39/mo billed annually)
STRIPE_PRICE_GROWTH_ANNUAL=     # price_... ($119/mo billed annually)
STRIPE_PRICE_ENTERPRISE=

# ── Litestream Backup (recommended for production) ───────────────────────────
LITESTREAM_BUCKET=
LITESTREAM_REGION=us-east-1
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_ENDPOINT=            # R2: https://<account_id>.r2.cloudflarestorage.com
LITESTREAM_PATH_STYLE=false     # true for R2/MinIO
